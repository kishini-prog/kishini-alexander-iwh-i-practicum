doctype html
html 
    head 
        title= `${title}`
        meta(name="viewport" content="width=device-width, initial-scale=1")
        link(rel="stylesheet", href="/css/style.css")
    body    
        h1 Pet Details

        a(href="/update-cobj") Add to this table
        
        table
            thead
                tr
                    th Dog Name
                    th Dog Breed
                    th Dog Age
            tbody
                each pet in data
                    tr
                        td #{pet.properties.pet_name}
                        td #{pet.properties.pet_breed}
                        td #{pet.properties.pet_age}