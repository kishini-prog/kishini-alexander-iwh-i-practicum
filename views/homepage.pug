doctype html
html 
    head 
        title= `${title}`
        meta(name="viewport" content="width=device-width, initial-scale=1")
        link(rel="stylesheet", href="/css/style.css")
    body    
        h1 Custom Object Table (Pets)
        a(href="/update-cobj") Add to this table
        
        table(style="margin-top: 20px; border-collapse: collapse; width: 100%;")
            thead
                tr(style="background-color: #ffcccb;")
                    th Name
                    th Breed
                    th Age
            tbody
                each pet in data
                    tr
                        td #{pet.properties.pet_name}
                        td #{pet.properties.pet_breed}
                        td #{pet.properties.pet_age}